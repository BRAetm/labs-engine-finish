app/build/
dist/
out/
*.user
*.user.*
.vs/
.vscode/
CMakeUserPresets.json
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.vcxproj*
*.dll
*.exe
*.lib
*.pdb
*.ilk
*.obj
*.o
*.exp

# Exception: bundled ViGEmBus installer ships with the source so the
# packaging script can pick it up. Tighten this pattern to the specific
# path so we don't accidentally track ffmpeg.exe or other tooling.
!app/third-party/ViGEmBus/*.exe

aqtinstall.log

.claude/settings.local.json

# Python
__pycache__/
*.pyc
*.pyo

# User-local settings
labs-engine/scripts/userdata/
labs-engine/userdata/

# Vendored third-party SDKs / clones — not source we author, downloaded
# by setup scripts (dl_webview2.ps1) or git clone. Don't bloat the repo.
app/third-party/greenlight/
app/third-party/webview2/

# Node sidecar build state — package.json + source files commit, but the
# 200MB+ of installed deps don't.
app/sidecars/*/node_modules/

# Runtime settings written by the running app
xdrive_settings.json
.claude/scheduled_tasks.lock
labs-engine/.claude/
